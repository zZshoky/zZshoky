# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://corpora:corpora_dev@db:5432/corpora

# ── Postgres (docker-compose db service) ─────────────────────────────────────
POSTGRES_USER=corpora
POSTGRES_PASSWORD=corpora_dev
POSTGRES_DB=corpora

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_SECRET_KEY=change_me_in_production
ALLOWED_ORIGINS=http://localhost:3000

# ── Next.js (exposed to browser bundle — keep non-sensitive) ──────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Security ──────────────────────────────────────────────────────────────────
IP_HASH_SALT=replace_with_random_string
